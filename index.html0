<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Sedang Maintenance - DUKOPS</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #0a1a3a, #1a3a6a, #0a2a4a);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .card {
            max-width: 450px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 40px 30px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .icon { font-size: 70px; color: #ffcc00; margin-bottom: 20px; animation: spin 2s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        h1 { color: #ffcc00; font-size: 24px; margin-bottom: 15px; }
        .badge { background: #ff6600; display: inline-block; padding: 5px 15px; border-radius: 30px; font-size: 12px; margin-bottom: 20px; color: white; }
        .msg { color: #ddd; line-height: 1.6; margin-bottom: 25px; }
        .timer { background: rgba(0,0,0,0.5); border-radius: 50px; padding: 15px; margin-bottom: 20px; }
        .timer-label { font-size: 11px; color: #aaa; }
        .timer-value { font-size: 32px; font-family: monospace; color: #4dff4d; font-weight: bold; }
        .progress-bar { background: rgba(255,255,255,0.2); border-radius: 10px; height: 6px; margin-top: 12px; overflow: hidden; }
        .progress-fill { background: linear-gradient(90deg, #ffcc00, #ff6600); width: 0%; height: 100%; transition: width 1s; }
        .contact { background: rgba(0,0,0,0.3); border-radius: 16px; padding: 15px; margin: 20px 0; color: #4dff4d; }
        .btn { background: #25D366; border: none; color: white; padding: 14px; border-radius: 50px; font-size: 16px; font-weight: bold; cursor: pointer; width: 100%; margin-top: 10px; }
        .btn:hover { background: #128C7E; }
        .refresh { margin-top: 15px; color: #aaa; font-size: 12px; cursor: pointer; text-decoration: underline; }
        .footer { margin-top: 20px; font-size: 10px; color: #888; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🔧</div>
        <h1>SISTEM DALAM PERBAIKAN</h1>
        <div class="badge">MAINTENANCE MODE</div>
        <div class="msg"> Maaf, aplikasi DUKOPS Babinsa sedang dalam pemeliharaan</div>
        <div class="timer">
            <div class="timer-label">⏱️ PERKIRAAN WAKTU</div>
            <div class="timer-value" id="timer">12:30:00</div>
            <div class="progress-bar"><div class="progress-fill" id="progress"></div></div>
        </div>
        <div class="contact">
            📞 Hubungi: Admin<br>
            <small>Admin Koramil Sukasada</small>
        </div>
        <button class="btn" id="waBtn">💬 CHAT LIVE ADMIN</button>
        <div class="refresh" onclick="location.reload()">🔄 Coba refresh halaman</div>
        <div class="footer">DUKOPS KORAMIL 1609-05/SUKASADA</div>
    </div>
    <script>
        // Konfigurasi
        const ADMIN_NUMBER = "6281234567890"; // Ganti nomor admin
        const DURASI = 30; // menit
        
        let sisa = DURASI * 60;
        const timerEl = document.getElementById('timer');
        const progressEl = document.getElementById('progress');
        const total = sisa;
        
        function updateTimer() {
            let jam = Math.floor(sisa / 3600);
            let menit = Math.floor((sisa % 3600) / 60);
            let detik = sisa % 60;
            timerEl.textContent = `${String(jam).padStart(2,'0')}:${String(menit).padStart(2,'0')}:${String(detik).padStart(2,'0')}`;
            let persen = ((total - sisa) / total) * 100;
            progressEl.style.width = persen + '%';
            if (sisa > 0) { sisa--; setTimeout(updateTimer, 1000); }
        }
        updateTimer();
        
        document.getElementById('waBtn').onclick = () => {
            let no = ADMIN_NUMBER.replace(/\D/g, '');
            if (no.startsWith('0')) no = '62' + no.substring(1);
            window.open(`https://wa.me/${no}?text=${encodeURIComponent('Halo Admin, maintenance DUKOPS masih berlangsung? Terima kasih.')}`, '_blank');
        };
    </script>
</body>
</html>
